[Unit]
Description=LaunchBot Flask/Gunicorn app
After=network.target ollama.service
Wants=ollama.service

[Service]
User=ec2-user
Group=nginx
WorkingDirectory=/var/www/launchbot/server
EnvironmentFile=/var/www/launchbot/server/.env
ExecStart=/var/www/launchbot/server/.venv/bin/gunicorn --workers 1 --threads 2 --timeout 300 --bind 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
